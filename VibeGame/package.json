{
  "name": "vibegame",
  "version": "0.3.5",
  "description": "a 3D game engine designed for vibe coding",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./defaults": {
      "types": "./dist/defaults.d.ts",
      "import": "./dist/defaults.js"
    },
    "./animation": {
      "types": "./dist/plugins/animation/index.d.ts",
      "import": "./dist/plugins/animation/index.js"
    },
    "./input": {
      "types": "./dist/plugins/input/index.d.ts",
      "import": "./dist/plugins/input/index.js"
    },
    "./orbit-camera": {
      "types": "./dist/plugins/orbit-camera/index.d.ts",
      "import": "./dist/plugins/orbit-camera/index.js"
    },
    "./physics": {
      "types": "./dist/plugins/physics/index.d.ts",
      "import": "./dist/plugins/physics/index.js"
    },
    "./player": {
      "types": "./dist/plugins/player/index.d.ts",
      "import": "./dist/plugins/player/index.js"
    },
    "./rendering": {
      "types": "./dist/plugins/rendering/index.d.ts",
      "import": "./dist/plugins/rendering/index.js"
    },
    "./transforms": {
      "types": "./dist/plugins/transforms/index.d.ts",
      "import": "./dist/plugins/transforms/index.js"
    },
    "./startup": {
      "types": "./dist/plugins/startup/index.d.ts",
      "import": "./dist/plugins/startup/index.js"
    },
    "./tweening": {
      "types": "./dist/plugins/tweening/index.d.ts",
      "import": "./dist/plugins/tweening/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./extras/gltf": {
      "types": "./dist/extras/gltf-bridge.d.ts",
      "import": "./dist/extras/gltf-bridge.js"
    },
    "./terrain": {
      "types": "./dist/plugins/terrain/index.d.ts",
      "import": "./dist/plugins/terrain/index.js"
    },
    "./bvh": {
      "types": "./dist/plugins/bvh/index.d.ts",
      "import": "./dist/plugins/bvh/index.js"
    },
    "./debug": {
      "types": "./dist/plugins/debug/index.d.ts",
      "import": "./dist/plugins/debug/index.js"
    },
    "./extras/sky": {
      "types": "./dist/extras/sky-env.d.ts",
      "import": "./dist/extras/sky-env.js"
    },
    "./particles": {
      "types": "./dist/plugins/particles/index.d.ts",
      "import": "./dist/plugins/particles/index.js"
    }
  },
  "files": [
    "dist",
    "llms.txt",
    "!dist/reference",
    "!dist/examples"
  ],
  "bin": {
    "vibegame": "./scripts/vibegame-cli.mjs"
  },
  "scripts": {
    "build": "vite build",
    "build:release": "bun scripts/prepare.ts && vite build && vite build --config vite.config.cdn.ts",
    "dev": "vite build --watch",
    "check": "tsc --noEmit",
    "example": "bun run build && cd examples/hello-world && bun run dev",
    "clean": "node scripts/clean.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "bun test tests/unit tests/integration tests/e2e",
    "playwright:install": "playwright install chromium",
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui",
    "test:playwright:debug": "playwright test --debug",
    "test:debug": "playwright test tests/playwright/debug-cycle.spec.ts tests/playwright/visual-regression.spec.ts --reporter=json"
  },
  "keywords": [
    "threejs",
    "game-engine",
    "vibe-coding",
    "ecs",
    "bitecs",
    "game-development",
    "3d",
    "character-controller"
  ],
  "author": "dylanebert",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maikramer/GameDev.git",
    "directory": "VibeGame"
  },
  "homepage": "https://github.com/maikramer/GameDev/tree/main/VibeGame",
  "bugs": {
    "url": "https://github.com/maikramer/GameDev/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "bitecs": ">=0.4.0",
    "three": ">=0.183.0"
  },
  "devDependencies": {
    "@fredli74/typr": "^0.3.9",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "@types/howler": "^2.2.13",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.0.1",
    "@types/three": "^0.185.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "ajv": "^8.20.0",
    "bitecs": "^0.4.0",
    "canvas": "^3.2.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-prettier": "^5.5.6",
    "glob": "^13.0.6",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "three": "^0.185.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@gltf-transform/core": "^4.4.0",
    "@gltf-transform/functions": "^4.4.0",
    "@recast-navigation/three": "^0.43.1",
    "colyseus.js": "^0.16.22",
    "gsap": "^3.15.0",
    "howler": "^2.2.4",
    "msgpackr": "^2.0.4",
    "recast-navigation": "^0.43.1",
    "three-mesh-bvh": "^0.9.10",
    "three-mesh-ui": "^6.5.4",
    "three-pathfinding": "^1.3.0",
    "three-stdlib": "^2.36.1",
    "three.quarks": "^0.17.1",
    "troika-three-text": "^0.52.4",
    "yaml": "^2.9.0",
    "yuka": "^0.7.8",
    "zod": "^4.4.3"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "@humanfs/types@0.15.0": true
  }
}
